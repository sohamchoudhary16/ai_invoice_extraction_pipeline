# ─────────────────────────────────────────────
#  .env.example  —  copy to .env and fill in
# ─────────────────────────────────────────────

# ── Tesseract ────────────────────────────────
# Windows default install path. Adjust if you installed elsewhere.
# Run `where tesseract` in your terminal to confirm.
# No account or API key needed — it's a local binary.
TESSERACT_PATH=C:\Users\SohamChoudhary\Downloads\Documents\tesseract\tesseract.exe

# ── Ollama ───────────────────────────────────
# Ollama runs locally — no API key required.
# Just ensure `ollama serve` is running before you start the pipeline.
# Default URL when running locally:
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5vl:7b
# OLLAMA_MODEL=llama3.2:3b
OLLAMA_TIMEOUT=1800

# ── OCR Confidence Threshold ─────────────────
# Words below this % confidence get sent to LLM for re-extraction.
# Start at 80, tune down if too many words are being flagged.
CONFIDENCE_THRESHOLD=80

# ── Paths ────────────────────────────────────
INPUT_DIR=sample_pdf/scan
OUTPUT_DIR=output
LOG_FILE=logs/logs.txt
